{% extends "base.jinja2" %}

{% block title %}申报详情 - 工作量+1{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto">
    <div class="bg-white rounded-xl shadow-sm p-4">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 mb-6">
            <div>
                <h2 class="text-xl font-bold text-gray-800">{{ period.title }}</h2>
                <p class="text-sm text-gray-500 mt-1">
                    {{ period.start_date.strftime('%Y-%m-%d') }} ~ {{ period.end_date.strftime('%Y-%m-%d') }}
                </p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <span
                    class="px-3 py-1 {% if period.is_open %}bg-green-100 text-green-600{% else %}bg-gray-100 text-gray-600{% endif %} rounded">
                    {% if period.is_open %}开放中{% else %}已关闭{% endif %}
                </span>
                <form action="/admin/export/download" method="POST">
                    <input type="hidden" name="dept_id" value="{{ period.dept_id }}">
                    <input type="hidden" name="period_id" value="{{ period.id }}">
                    <button type="submit"
                        class="px-3 py-1.5 text-sm bg-green-600 text-white rounded hover:bg-green-700 w-full sm:w-auto">一键导出</button>
                </form>
            </div>
        </div>

        {% if saved %}
        <div class="mb-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
            已保存项目状态和总结
        </div>
        {% endif %}

        <div class="mb-8">
            <div class="mb-3">
                <h3 class="text-lg font-bold text-gray-800">项目阶段状态与总结</h3>
            </div>

            {% if project_summary_rows %}
            <form action="/admin/settlement/{{ period.id }}/project-summaries" method="POST" class="space-y-4">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
                    {% for row in project_summary_rows %}
                    <div class="rounded-lg border {% if selected_project_id and selected_project_id == row.project.id %}border-blue-400 ring-1 ring-blue-200{% else %}border-gray-200{% endif %} p-3 bg-white min-w-0">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <a href="/admin/settlement/{{ period.id }}/claims?project_id={{ row.project.id }}{% if selected_user_id %}&user_id={{ selected_user_id }}{% endif %}"
                                   class="font-medium text-gray-800 break-words hover:text-blue-600 hover:underline">
                                    {{ row.project.name }}
                                </a>
                                <p class="text-xs text-gray-500 mt-1">{{ row.record_count }} 条 · {{
                                    "%.1f"|format(row.total_hours) }} 小时</p>
                            </div>
                        </div>
                        <input type="hidden" name="project_id" value="{{ row.project.id }}">
                        <div class="mt-3">
                            <label class="block text-xs text-gray-600 mb-1">状态</label>
                            <select name="status" required title="项目状态" aria-label="项目状态"
                                class="w-full px-2 py-1.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-sm">
                                {% for option in project_status_options %}
                                <option value="{{ option }}" {% if option==row.status %}selected{% endif %}>{{ option }}
                                </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mt-3">
                            <label class="block text-xs text-gray-600 mb-1">总结</label>
                            <textarea name="summary" rows="3" required title="项目总结" aria-label="项目总结"
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-sm"
                                placeholder="填写该项目在本结算周期内的执行情况、产出和后续安排">{{ row.summary }}</textarea>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                <div class="flex justify-end">
                    <button type="submit"
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">保存项目状态与总结</button>
                </div>
            </form>
            {% else %}
            <div class="rounded-lg border border-dashed border-gray-300 bg-gray-50 px-4 py-6 text-sm text-gray-500">
                当前结算周期没有关联到任何工作记录，暂无项目可填写。
            </div>
            {% endif %}
        </div>

        <h3 class="text-lg font-bold text-gray-800 mb-3">成员申报详情</h3>

        {% set claimed_members = member_data | selectattr("claim") | list %}

        <!-- 桌面端：左右两列布局 -->
        <div class="hidden lg:grid lg:grid-cols-12 lg:gap-4">
            <!-- 左侧：成员列表 -->
            <div class="col-span-4 xl:col-span-3">
                <div class="rounded-lg border border-gray-200 overflow-hidden">
                    <div class="bg-gray-50 px-4 py-2 border-b border-gray-200">
                        <p class="text-sm font-medium text-gray-700">
                            已申报成员 ({{ claimed_members | length }})
                        </p>
                    </div>
                    <div class="divide-y divide-gray-100 max-h-[500px] overflow-y-auto">
                        {% for item in claimed_members %}
                        <a href="/admin/settlement/{{ period.id }}/claims?user_id={{ item.user.id }}{% if selected_project_id %}&project_id={{ selected_project_id }}{% endif %}"
                            class="block px-4 py-3 hover:bg-blue-50 transition {% if selected_user_id and item.user.id == selected_user_id %}bg-blue-50 border-l-4 border-blue-500{% else %}border-l-4 border-transparent{% endif %}">
                            <div class="flex items-center justify-between">
                                <span class="font-medium text-gray-800">{{ item.user.name }}</span>
                                <span class="text-xs text-green-600 bg-green-100 px-2 py-0.5 rounded">已提交</span>
                            </div>
                            <div class="mt-1 text-xs text-gray-500">
                                <span class="text-blue-600">工资 {{ "%.1f"|format(item.claim.paid_hours) }}h</span>
                                <span class="mx-1">|</span>
                                <span class="text-green-600">志愿 {{ "%.1f"|format(item.claim.volunteer_hours) }}h</span>
                                <span class="mx-1">|</span>
                                <span class="text-gray-700">共 {{ "%.1f"|format(item.claim.total_hours) }}h</span>
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- 右侧：工作记录列表 -->
            <div class="col-span-8 xl:col-span-9">
                <div class="rounded-lg border border-gray-200 overflow-hidden">
                    <div class="bg-gray-50 px-4 py-2 border-b border-gray-200 flex items-center justify-between flex-wrap gap-2">
                        <p class="text-sm font-medium text-gray-700">
                            {% if selected_member_detail and selected_project %}
                            {{ selected_member_detail.user.name }} 在 {{ selected_project.name }} 的申报记录
                            {% elif selected_member_detail %}
                            {{ selected_member_detail.user.name }} 的申报记录
                            {% elif selected_project %}
                            {{ selected_project.name }} 的申报记录
                            {% else %}
                            全部申报记录
                            {% endif %}
                        </p>
                        {% if selected_user_id or selected_project_id %}
                        <a href="/admin/settlement/{{ period.id }}/claims" class="text-xs text-blue-600 hover:underline">显示全部</a>
                        {% endif %}
                    </div>
                    <div class="max-h-[500px] overflow-y-auto">
                        {% if selected_member_records %}
                        <!-- 移动端卡片布局 -->
                        <div class="md:hidden space-y-3 p-4">
                            {% for record in selected_member_records %}
                            <div class="border border-gray-200 rounded-lg p-3 bg-white">
                                <div class="flex items-start justify-between gap-3">
                                    <div class="min-w-0 flex-1">
                                        <p class="text-xs text-gray-500">{{ record.created_at.strftime('%m/%d %H:%M') }}</p>
                                        <p class="text-sm font-medium text-gray-800 break-words">
                                            {% if not selected_user_id %}{{ record.user.name }} · {% endif %}
                                            {% if not selected_project_id %}{{ record.project.name }}{% endif %}
                                        </p>
                                    </div>
                                    <p class="text-sm text-blue-600 font-medium whitespace-nowrap">
                                        {{ '%.1f'|format(record.duration_minutes / 60) }} 小时</p>
                                </div>
                                <p class="mt-2 text-sm text-gray-600 break-words">{{ record.description }}</p>
                            </div>
                            {% endfor %}
                        </div>

                        <!-- 桌面端表格布局 -->
                        <div class="hidden md:block">
                            <table class="w-full text-sm">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="px-4 py-2 text-left text-gray-600">时间</th>
                                        {% if not selected_user_id %}
                                        <th class="px-4 py-2 text-left text-gray-600">成员</th>
                                        {% endif %}
                                        {% if not selected_project_id %}
                                        <th class="px-4 py-2 text-left text-gray-600">项目</th>
                                        {% endif %}
                                        <th class="px-4 py-2 text-left text-gray-600">描述</th>
                                        <th class="px-4 py-2 text-right text-gray-600">时长</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    {% for record in selected_member_records %}
                                    <tr class="hover:bg-gray-50">
                                        <td class="px-4 py-3 text-gray-500 whitespace-nowrap">{{ record.created_at.strftime('%m/%d %H:%M') }}</td>
                                        {% if not selected_user_id %}
                                        <td class="px-4 py-3">
                                            <a href="/admin/settlement/{{ period.id }}/claims?user_id={{ record.user.id }}{% if selected_project_id %}&project_id={{ selected_project_id }}{% endif %}"
                                               class="text-blue-700 hover:underline">{{ record.user.name }}</a>
                                        </td>
                                        {% endif %}
                                        {% if not selected_project_id %}
                                        <td class="px-4 py-3">
                                            <a href="/admin/settlement/{{ period.id }}/claims?project_id={{ record.project.id }}{% if selected_user_id %}&user_id={{ selected_user_id }}{% endif %}"
                                               class="text-blue-700 hover:underline">{{ record.project.name }}</a>
                                        </td>
                                        {% endif %}
                                        <td class="px-4 py-3 text-gray-600 max-w-lg break-words">{{ record.description }}</td>
                                        <td class="px-4 py-3 text-right text-blue-600 font-medium whitespace-nowrap">{{ '%.1f'|format(record.duration_minutes / 60) }} 小时</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        {% else %}
                        <div class="px-4 py-8 text-sm text-gray-500 text-center">
                            {% if selected_member_detail %}该成员在本周期没有工作记录。{% elif selected_project %}该项目在本周期没有工作记录。{% else %}请选择成员或项目查看申报记录{% endif %}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <!-- 移动端：保持原有卡片布局 -->
        <div class="lg:hidden">
            <div class="space-y-3">
                {% for item in claimed_members %}
                <a href="/admin/settlement/{{ period.id }}/claims?user_id={{ item.user.id }}#member-detail"
                    class="block border rounded-lg p-3 bg-white min-w-0 transition {% if selected_user_id and item.user.id == selected_user_id %}border-blue-400 ring-1 ring-blue-200{% else %}border-gray-200 hover:border-blue-300{% endif %}">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="font-medium text-gray-800">{{ item.user.name }}</p>
                        </div>
                        <div>
                            <span class="px-2 py-1 bg-green-100 text-green-600 text-xs rounded">已提交</span>
                        </div>
                    </div>

                    <div class="mt-3 grid grid-cols-3 gap-2 text-xs">
                        <div class="rounded bg-gray-50 px-2 py-1.5">
                            <p class="text-gray-500">工资时长</p>
                            <p class="text-blue-600 mt-0.5">{{ "%.1f"|format(item.claim.paid_hours) }} 小时</p>
                        </div>
                        <div class="rounded bg-gray-50 px-2 py-1.5">
                            <p class="text-gray-500">志愿时长</p>
                            <p class="text-green-600 mt-0.5">{{ "%.1f"|format(item.claim.volunteer_hours) }} 小时</p>
                        </div>
                        <div class="rounded bg-gray-50 px-2 py-1.5">
                            <p class="text-gray-500">申报总时长</p>
                            <p class="text-gray-800 mt-0.5 font-medium">{{ "%.1f"|format(item.claim.total_hours) }} 小时</p>
                        </div>
                    </div>
                </a>
                {% endfor %}
            </div>

            {% if selected_member_detail %}
            <div id="member-detail" class="mt-4 border border-blue-200 bg-blue-50/40 rounded-lg p-4">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
                    <h4 class="text-base font-semibold text-gray-800">
                        {{ selected_member_detail.user.name }} 的申报明细
                    </h4>
                    <a href="/admin/settlement/{{ period.id }}/claims"
                        class="text-sm text-blue-600 hover:underline">关闭详情</a>
                </div>

                <div class="grid grid-cols-3 gap-2 text-xs mb-4">
                    <div class="rounded bg-white px-3 py-2 border border-blue-100">
                        <p class="text-gray-500">工资时长</p>
                        <p class="text-blue-700 mt-0.5">{{ "%.1f"|format(selected_member_detail.claim.paid_hours) }} 小时</p>
                    </div>
                    <div class="rounded bg-white px-3 py-2 border border-blue-100">
                        <p class="text-gray-500">志愿时长</p>
                        <p class="text-green-700 mt-0.5">{{ "%.1f"|format(selected_member_detail.claim.volunteer_hours) }} 小时</p>
                    </div>
                    <div class="rounded bg-white px-3 py-2 border border-blue-100">
                        <p class="text-gray-500">提交时间</p>
                        <p class="text-gray-800 mt-0.5">{{ selected_member_detail.claim.submitted_at.strftime('%Y-%m-%d %H:%M') }}</p>
                    </div>
                </div>

                <div class="rounded-lg border border-gray-200 bg-white overflow-hidden">
                    {% if selected_member_records %}
                    <div class="divide-y divide-gray-100">
                        {% for record in selected_member_records %}
                        <div class="px-3 py-2 text-xs sm:text-sm">
                            <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0 flex-1">
                                    <div class="flex items-center gap-2">
                                        <span class="text-gray-500">{{ record.created_at.strftime('%m/%d %H:%M') }}</span>
                                        {% if not selected_project_id %}
                                        <span class="font-medium text-gray-800 truncate">{{ record.project.name }}</span>
                                        {% endif %}
                                    </div>
                                    <p class="text-gray-600 mt-1 break-words">{{ record.description }}</p>
                                </div>
                                <span class="text-blue-600 font-medium whitespace-nowrap">{{ '%.1f'|format(record.duration_minutes / 60) }}h</span>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="px-4 py-6 text-sm text-gray-500">该成员在本周期没有工作记录。</div>
                    {% endif %}
                </div>
            </div>
            {% endif %}
        </div>

        <div class="mt-6">
            <a href="/admin/settlement?dept_id={{ period.dept_id }}"
                class="px-4 py-2 text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50">
                返回
            </a>
        </div>
    </div>
</div>
{% endblock %}