{% extends "base.jinja2" %}

{% block title %}记录查询 - 工作量+1{% endblock %}

{% block content %}
<div class="space-y-6">
    <!-- 筛选器 -->
    <div class="bg-white rounded-xl shadow-sm p-4">
        <form class="flex flex-wrap items-center gap-4">
            <input type="hidden" name="dept_id" value="{{ dept_id }}">

            <div class="flex items-center space-x-2">
                <label class="text-sm text-gray-600">开始:</label>
                <input type="date" name="start_date" value="{{ start_date or '' }}" title="开始日期"
                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
            </div>

            <div class="flex items-center space-x-2">
                <label class="text-sm text-gray-600">结束:</label>
                <input type="date" name="end_date" value="{{ end_date or '' }}" title="结束日期"
                    class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
            </div>

            <div class="flex items-center space-x-2">
                <label class="text-sm text-gray-600">成员:</label>
                <select name="user_id" title="按成员筛选" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
                    <option value="">全部</option>
                    {% for m in members %}
                    <option value="{{ m.id }}" {% if m.id==selected_user_id %}selected{% endif %}>
                        {{ m.name }}
                    </option>
                    {% endfor %}
                </select>
            </div>

            <div class="flex items-center space-x-2">
                <label class="text-sm text-gray-600">项目:</label>
                <select name="project_id" title="按项目筛选" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
                    <option value="">全部</option>
                    {% for p in projects %}
                    <option value="{{ p.id }}" {% if p.id==selected_project_id %}selected{% endif %}>
                        {{ p.name }}
                    </option>
                    {% endfor %}
                </select>
            </div>

            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm">
                筛选
            </button>
        </form>
    </div>

    <!-- 记录列表 -->
    <div class="bg-white rounded-xl shadow-sm p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4">
            工作记录 <span class="text-sm text-gray-500 font-normal">({{ records|length }} 条)</span>
        </h3>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-gray-600">时间</th>
                        <th class="px-4 py-2 text-left text-gray-600">成员</th>
                        <th class="px-4 py-2 text-left text-gray-600">项目</th>
                        <th class="px-4 py-2 text-left text-gray-600">描述</th>
                        <th class="px-4 py-2 text-right text-gray-600">时长</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for r in records %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 text-gray-500">{{ r.created_at.strftime('%m/%d %H:%M') }}</td>
                        <td class="px-4 py-3">{{ r.user.name }}</td>
                        <td class="px-4 py-3">{{ r.project.name }}</td>
                        <td class="px-4 py-3 text-gray-600 max-w-xs truncate">{{ r.description }}</td>
                        <td class="px-4 py-3 text-right text-blue-600 font-medium">
                            {{ '%.1f'|format(r.duration_minutes / 60) }} 小时
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="px-4 py-8 text-center text-gray-400">暂无记录</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}